NODE_ENV=development
PORT=4000

# Supabase Transaction Pooler (PgBouncer, port 6543) — for application runtime
# REQUIRED: pgbouncer=true disables prepared statements (incompatible with PgBouncer transaction mode)
# REQUIRED: connection_limit=1 prevents exhausting connections during hot-reload in development
DATABASE_URL="postgresql://<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Supabase direct connection (port 5432) — for Prisma Migrate / Studio only (bypasses PgBouncer)
DIRECT_URL="postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres"

JWT_SECRET=your-secret-key-minimum-16-chars
JWT_REFRESH_SECRET=your-refresh-secret-key-minimum-16-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

CORS_ORIGIN=http://localhost:3000

# ── AI Provider ────────────────────────────────────────────────────────
# Options: gemini (default) | nvidia | mock
AI_PROVIDER=gemini
AI_PREFERRED_MODEL=gemini-1.5-flash
AI_FALLBACK_MODELS=gemini-1.5-pro,gemini-2.0-flash-exp
AI_TEMPERATURE=0.2
AI_TOP_P=0.8
AI_MAX_OUTPUT_TOKENS=1024

# Gemini (default provider — required when AI_PROVIDER=gemini)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# NVIDIA NIM (legacy fallback — required when AI_PROVIDER=nvidia)
NVIDIA_API_KEY=your-nvidia-api-key
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_TEXT_MODEL=meta/llama-3.1-70b-instruct
NVIDIA_VISION_MODEL=meta/llama-3.2-90b-vision-instruct

# ── Threat Intelligence APIs ────────────────────────────────────────────
# Optional — system degrades gracefully when absent
GOOGLE_SAFE_BROWSING_API_KEY=your-google-safe-browsing-key
VIRUSTOTAL_API_KEY=your-virustotal-api-key

# ── AI Configuration Parameters ──────────────────────────────────────────
# AI Cache Config
AI_SCAN_CACHE_ENABLED=true
AI_CHAT_CACHE_ENABLED=true
AI_SCAN_CACHE_TTL_DAYS=7
AI_CHAT_CACHE_TTL_DAYS=30

# Circuit Breaker Config
AI_CIRCUIT_BREAKER_ENABLED=true
AI_CIRCUIT_BREAKER_FAILURES=5
AI_CIRCUIT_BREAKER_TIMEOUT_SECONDS=120

# Retry Policy Config
AI_MAX_RETRIES=2
AI_REQUEST_TIMEOUT_MS=20000
AI_RETRY_DELAY_MS=1500

# AI Routing Config
AI_USE_FOR_SAFE_SCANS=false
AI_USE_FOR_LOW_SCANS=false
AI_USE_FOR_MEDIUM_SCANS=true
AI_USE_FOR_HIGH_SCANS=true
AI_USE_FOR_CRITICAL_SCANS=true

# AEGIS Config
AEGIS_MAX_CONTEXT_MESSAGES=10
AEGIS_MAX_RECENT_SCANS=3
AEGIS_MAX_RECENT_REPORTS=2
AEGIS_CONTEXT_COMPRESSION=true

# Logging Config
AI_DEBUG_LOGGING=true

# ── Fake Currency ML Service ─────────────────────────────────────────────────
CURRENCY_ML_URL=http://localhost:8000

